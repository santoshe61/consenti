{
  "name": "@consenti/ui",
  "version": "0.2.0",
  "description": "Zero-dependency GDPR cookie consent widget",
  "license": "Apache-2.0",
  "keywords": [
    "gdpr",
    "cookie-consent",
    "cmp",
    "ccpa",
    "privacy",
    "consent-management",
    "cookie-banner",
    "typescript"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/santoshe61/consenti.git"
  },
  "homepage": "https://consenti.dev",
  "bugs": {
    "url": "https://github.com/santoshe61/consenti/issues"
  },
  "type": "module",
  "main": "./dist/index.umd.js",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.umd.js"
    },
    "./react": {
      "types": "./dist/react.d.ts",
      "import": "./dist/react.mjs",
      "require": "./dist/react.js"
    },
    "./vue": {
      "types": "./dist/vue.d.ts",
      "import": "./dist/vue.mjs",
      "require": "./dist/vue.js"
    },
    "./angular": {
      "types": "./dist/angular.d.ts",
      "import": "./dist/angular.mjs",
      "require": "./dist/angular.js"
    },
    "./testing": {
      "types": "./dist/testing.d.ts",
      "import": "./dist/testing.mjs",
      "require": "./dist/testing.js"
    },
    "./style": {
      "types": "./dist/style.d.ts",
      "default": "./dist/index.css"
    },
    "./dist/*": "./dist/*"
  },
  "sideEffects": [
    "./dist/index.css"
  ],
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup && npm run build:css",
    "dev:build": "tsup --watch",
    "dev:vite": "vite",
    "dev": "npm run dev:vite & npm run dev:build",
    "watch": "tsup --watch",
    "typecheck": "tsc --noEmit",
    "build:css": "node scripts/build-css.mjs",
    "test": "tsx --test src/__tests__/*.integration.ts"
  },
  "devDependencies": {
    "@consenti/types": "*",
    "@consenti/utils": "*",
    "@types/node": "^26.1.1",
    "@types/react": "^19.0.0",
    "tsx": "^4.23.0",
    "vue": "^3.5.0",
    "sass": "^1.89.2",
    "tsup": "^8.5.0",
    "typescript": "^6.0.3",
    "vite": "^8.1.3"
  },
  "peerDependencies": {
    "react": ">=18.0.0",
    "vue": ">=3.0.0"
  },
  "peerDependenciesMeta": {
    "react": {
      "optional": true
    },
    "vue": {
      "optional": true
    }
  },
  "packageManager": "npm@10.9.2",
  "engines": {
    "node": ">=20.0.0",
    "npm": ">=10.0.0"
  }
}