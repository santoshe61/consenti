{
  "name": "@consenti/api",
  "version": "0.1.0",
  "description": "Zero-dependency GDPR-compliant Consent Management Platform backend",
  "license": "Apache-2.0",
  "keywords": [
    "gdpr",
    "consent-management",
    "cmp",
    "ccpa",
    "privacy",
    "cookie-consent",
    "admin-dashboard",
    "typescript",
    "node"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/santoshe61/consenti.git"
  },
  "homepage": "https://consenti.dev",
  "bugs": {
    "url": "https://github.com/santoshe61/consenti/issues"
  },
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "buildonly": "tsup",
    "watch": "tsup --watch",
    "build:api": "tsup && node scripts/fix-node-prefix.mjs && node scripts/copy-widget.mjs",
    "build:dashboard": "cd src/dashboard && vite build --config vite.config.ts",
    "build": "npm run build:api && npm run build:dashboard",
    "dev:server": "tsx --watch scripts/dev-server.ts",
    "dev:dashboard": "vite --config src/dashboard/vite.config.ts",
    "dev": "npm run dev:dashboard & npm run dev:server",
    "typecheck": "tsc --noEmit"
  },
  "devDependencies": {
    "@consenti/types": "*",
    "@preact/preset-vite": "^2.8.1",
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^22.0.0",
    "@types/pg": "^8.11.0",
    "autoprefixer": "^10.4.21",
    "mongodb": "^7.4.0",
    "mysql2": "^3.0.0",
    "node-sqlite3-wasm": "^0.8.59",
    "pg": "^8.0.0",
    "postcss": "^8.5.5",
    "preact": "^10.26.9",
    "tailwindcss": "^3.4.17",
    "tsup": "^8.5.0",
    "typescript": "^5.8.3",
    "vite": "^6.3.5"
  },
  "peerDependencies": {
    "better-sqlite3": "^12.11.1",
    "mongodb": ">=6.0.0",
    "mysql2": ">=3.0.0",
    "node-sqlite3-wasm": "^0.8.59",
    "pg": ">=8.0.0"
  },
  "peerDependenciesMeta": {
    "node-sqlite3-wasm": {
      "optional": true
    },
    "better-sqlite3": {
      "optional": true
    },
    "mongodb": {
      "optional": true
    },
    "mysql2": {
      "optional": true
    },
    "pg": {
      "optional": true
    }
  },
  "packageManager": "npm@10.9.2",
  "engines": {
    "node": ">=20.0.0",
    "npm": ">=10.0.0"
  }
}
