# ─── General ─────────────────────────────────────────────────────────────────
NODE_ENV=development

# ─── Server ──────────────────────────────────────────────────────────────────
CONSENTI_BASE_PATH=/consenti
# Maximum request body size in bytes (optional; omit to use the built-in default)
CONSENTI_MAX_BODY_SIZE=

# ─── Storage ─────────────────────────────────────────────────────────────────
# driver: json | sqlite | postgresql | mysql | mongodb
CONSENTI_DB_DRIVER=json
# Used when driver=json or driver=sqlite
CONSENTI_DB_PATH=./consenti-data.json

# Used when driver=postgresql | mysql | mongodb
CONSENTI_DB_URI=
# PostgreSQL / MySQL / Mongo — database name if not in URI
CONSENTI_DB_DATABASE=

# PostgreSQL / MySQL — database details
CONSENTI_DB_HOST=
CONSENTI_DB_PORT=
CONSENTI_DB_USER=
CONSENTI_DB_PASSWORD=

# ─── Auth — local mode ───────────────────────────────────────────────────────
CONSENTI_ADMIN_EMAIL=user@consenti.dev
# Min 12 chars; 16+ recommended. Hashed with scrypt on first boot.
CONSENTI_ADMIN_PASSWORD=ChangeMe@123!
# Stable random secret for JWT session cookies. Auto-generated (changes on restart) if omitted.
CONSENTI_ADMIN_JWT_SECRET=

# ─── Auth — OIDC mode (optional) ─────────────────────────────────────────────
OIDC_CLIENT_ID=
OIDC_CLIENT_SECRET=

# ─── Auth — SAML mode (optional) ─────────────────────────────────────────────
# IdP signing certificate in PEM format (without headers)
IDP_CERT=

# ─── Rate Limiting ────────────────────────────────────────────────────────────
CONSENTI_RATE_LIMIT_WINDOW_MS=60000
CONSENTI_RATE_LIMIT_MAX_REQUESTS=60

# ─── Dashboard SPA — Vite dev proxy only ─────────────────────────────────────
CONSENTI_API_URL=http://localhost:3001
