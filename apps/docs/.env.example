# ─── General ─────────────────────────────────────────────────────────────────
NODE_ENV=development

# ─── Consenti backend (lib/consenti.ts) ──────────────────────────────────────
# Stable secret used to sign admin JWT session cookies. Change before deploying.
CONSENTI_JWT_SECRET=change-me-before-deploy
# Admin credentials for the embedded Consenti dashboard.
CONSENTI_ADMIN_EMAIL=admin@consenti.dev
CONSENTI_ADMIN_PASSWORD=Consenti@123
# Filesystem path for the JSON storage driver. Defaults to ./consenti-data
CONSENTI_DATA_PATH=./consenti-data

# ─── Public API URL ───────────────────────────────────────────────────────────
# Exposed to the browser — must start with NEXT_PUBLIC_
NEXT_PUBLIC_API_URL=http://localhost:3001

# ─── Algolia DocSearch ────────────────────────────────────────────────────────
# Obtain from https://docsearch.algolia.com or your Algolia dashboard.
# appId and search API key are safe to expose publicly (read-only, domain-scoped).
NEXT_PUBLIC_ALGOLIA_APP_ID=
NEXT_PUBLIC_ALGOLIA_SEARCH_API_KEY=
NEXT_PUBLIC_ALGOLIA_INDEX_NAME=Consenti Doc
# Server-side write key — never expose to the browser
ALGOLIA_ADMIN_API_KEY=

# ─── Google reCAPTCHA v3 ──────────────────────────────────────────────────────
# Site key is safe to expose to the browser.
NEXT_PUBLIC_RECAPTCHA_SITE_KEY=
# Secret key is server-side only — never expose to the browser.
RECAPTCHA_SECRET_KEY=
